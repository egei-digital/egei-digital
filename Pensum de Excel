:root{
  --bg:#06120c;
  --panel:rgba(10,28,18,.78);
  --line:rgba(255,255,255,.12);
  --green:#20c574;
  --text:#f4fff8;
  --muted:#a9c4b5;
}
*{box-sizing:border-box}
html,body{margin:0;width:100%;height:100%;overflow:hidden;background:
radial-gradient(circle at 20% 10%,rgba(32,197,116,.17),transparent 34%),
radial-gradient(circle at 80% 90%,rgba(0,110,65,.24),transparent 38%),var(--bg);
font-family:Inter,Segoe UI,Arial,sans-serif;color:var(--text)}
button,input,a{-webkit-tap-highlight-color:transparent}
.app{height:100dvh;display:grid;grid-template-rows:auto 1fr auto;position:relative}
.topbar{height:68px;display:flex;align-items:center;justify-content:space-between;padding:10px 18px;background:linear-gradient(180deg,rgba(2,12,7,.92),rgba(2,12,7,.55));border-bottom:1px solid var(--line);backdrop-filter:blur(18px);z-index:20}
.brand{display:flex;align-items:center;gap:10px}
.brand-mark{width:38px;height:38px;border-radius:11px;display:grid;place-items:center;font-weight:900;font-size:22px;background:linear-gradient(145deg,#2ee58b,#0c854b);box-shadow:0 8px 24px rgba(24,199,112,.25)}
.brand strong{display:block;font-size:14px;letter-spacing:.08em}
.brand span{display:block;font-size:11px;color:var(--muted);margin-top:2px}
.top-actions{display:flex;gap:8px}
.icon-btn,.cta{border:1px solid var(--line);background:rgba(255,255,255,.065);color:var(--text);border-radius:12px;padding:10px 13px;font-weight:700;cursor:pointer;text-decoration:none}
.icon-btn:hover{background:rgba(255,255,255,.12)}
.viewer{min-height:0;position:relative;display:flex;align-items:center;justify-content:center;padding:14px 72px 8px}
.book{height:min(calc(100dvh - 164px),820px);max-width:calc(100vw - 150px);aspect-ratio:1.408/1;display:grid;grid-template-columns:1fr 3px 1fr;position:relative;filter:drop-shadow(0 28px 35px rgba(0,0,0,.48));perspective:2200px}
.sheet{overflow:hidden;background:#0b0b0b;position:relative}
.sheet.left{border-radius:8px 0 0 8px}
.sheet.right{border-radius:0 8px 8px 0}
.sheet img{width:100%;height:100%;display:block;object-fit:contain;background:#111;user-select:none;-webkit-user-drag:none}
.gutter{background:linear-gradient(90deg,rgba(0,0,0,.72),rgba(255,255,255,.08),rgba(0,0,0,.72));z-index:3}
.turn-sheet{position:absolute;top:0;right:0;width:50%;height:100%;transform-origin:left center;display:none;z-index:9;backface-visibility:hidden;box-shadow:-12px 0 30px rgba(0,0,0,.38);overflow:hidden}
.turn-sheet img{width:100%;height:100%;object-fit:contain;background:#111}
.turn-sheet.forward{display:block;animation:turnForward .62s cubic-bezier(.2,.72,.18,1)}
.turn-sheet.backward{display:block;left:0;right:auto;transform-origin:right center;animation:turnBackward .62s cubic-bezier(.2,.72,.18,1)}
@keyframes turnForward{0%{transform:rotateY(0);filter:brightness(1)}45%{filter:brightness(.72)}100%{transform:rotateY(-180deg);filter:brightness(.98)}}
@keyframes turnBackward{0%{transform:rotateY(0);filter:brightness(1)}45%{filter:brightness(.72)}100%{transform:rotateY(180deg);filter:brightness(.98)}}
.nav{position:absolute;top:50%;transform:translateY(-50%);width:48px;height:66px;border:1px solid var(--line);border-radius:16px;background:rgba(5,20,12,.72);color:#fff;font-size:42px;line-height:1;cursor:pointer;backdrop-filter:blur(14px);z-index:12}
.nav:hover{background:rgba(32,197,116,.25)}
.nav.prev{left:14px}.nav.next{right:14px}
.nav:disabled{opacity:.22;cursor:default}
.controls{height:68px;display:grid;grid-template-columns:auto minmax(120px,520px) auto;align-items:center;justify-content:center;gap:16px;padding:10px 18px;background:linear-gradient(0deg,rgba(2,12,7,.96),rgba(2,12,7,.55));border-top:1px solid var(--line);backdrop-filter:blur(18px);z-index:20}
#counter{font-size:13px;font-weight:800;min-width:60px;text-align:center}
#progress{width:100%;accent-color:var(--green)}
.cta{background:linear-gradient(145deg,#27d980,#139454);border:0;box-shadow:0 10px 24px rgba(24,199,112,.25)}
.hint{position:fixed;left:50%;bottom:82px;transform:translateX(-50%);padding:9px 13px;background:rgba(0,0,0,.72);border:1px solid var(--line);border-radius:999px;font-size:12px;color:#eafff2;opacity:0;pointer-events:none;animation:hint 4s .8s both;z-index:30}
@keyframes hint{0%,100%{opacity:0;transform:translate(-50%,8px)}15%,75%{opacity:1;transform:translate(-50%,0)}}
@media(max-width:760px){
  .topbar{height:58px;padding:8px 10px}
  .brand span{display:none}.brand strong{font-size:12px}.brand-mark{width:34px;height:34px}
  .icon-btn{font-size:0;width:38px;height:38px;padding:0}
  .icon-btn:before{font-size:18px}
  #shareBtn:before{content:"↗"}#fullBtn:before{content:"⛶"}
  .viewer{padding:8px 44px 4px}
  .book{height:auto;width:min(calc(100vw - 88px),calc((100dvh - 136px)*.704));aspect-ratio:.704/1;display:block}
  .sheet{position:absolute;inset:0;border-radius:8px!important}
  .sheet.left{display:none}
  .sheet.right{display:block}
  .gutter{display:none}
  .turn-sheet{width:100%;border-radius:8px;transform-origin:left center}
  .turn-sheet.backward{left:0;transform-origin:right center}
  .nav{width:38px;height:56px;font-size:34px;border-radius:13px}
  .nav.prev{left:4px}.nav.next{right:4px}
  .controls{height:62px;grid-template-columns:auto 1fr auto;gap:8px;padding:8px 10px}
  .cta{padding:10px 11px;font-size:12px}
}

/* Ajuste para mostrar cada página completa, sin cortar la parte superior ni inferior */
.sheet,.turn-sheet{background:#111}
.sheet img,.turn-sheet img{object-position:center center}
